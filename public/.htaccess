Options -MultiViews
RewriteEngine On

# Pass CGI API requests through to Apache unchanged
RewriteCond %{REQUEST_URI} ^/cgi/ [NC]
RewriteRule ^ - [L]

# Serve existing files and directories directly
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Route everything else to index.html so Angular's router takes over
RewriteRule ^ index.html [QSA,L]
